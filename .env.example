# ===== AI财务管理系统 环境配置 =====
# 复制此文件为 .env 并填入实际值
# .env 文件已加入 .gitignore，不会上传到 GitHub

# Deepseek API Key（AI助手功能必需）
# 前往 https://platform.deepseek.com 注册获取
# 留空则超级管理员登录后可在 系统配置 页面填入
DEEPSEEK_API_KEY=

# 数据库路径（默认 SQLite 无需修改）
DATABASE_URL=sqlite:///finance.db

# JWT 密钥（生产环境请修改为随机字符串）
SECRET_KEY=change-this-to-a-secure-random-key-in-production
